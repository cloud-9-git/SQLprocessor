{
    "tasks": [
    {
            "type": "cppbuild",
            "label": "C/C++: gcc build SQLprocessor",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${fileDirname}/main.c",
                "${fileDirname}/lexer.c",
                "${fileDirname}/parser.c",
                "${fileDirname}/executor.c",
                "-o",
                "${fileDirname}/sqlsprocessor"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}
